<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F8FAFC">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="New Enrollment"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1E293B"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/edtUserName"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Enter User Name"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="24dp"
        android:elevation="2dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp"
        android:weightSum="2">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Left Eye"
                android:textStyle="bold"
                android:textColor="#334155"
                android:layout_marginBottom="8dp"/>

            <ImageView
                android:id="@+id/imgLeftEye"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:src="@drawable/logo"
                android:background="#E2E8F0"
                android:scaleType="fitCenter"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/txtLeftQuality"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#22C55E"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Right Eye"
                android:textStyle="bold"
                android:textColor="#334155"
                android:layout_marginBottom="8dp"/>

            <ImageView
                android:id="@+id/imgRightEye"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:src="@drawable/logo"
                android:background="#E2E8F0"
                android:scaleType="fitCenter"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/txtRightQuality"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#22C55E"
                android:textStyle="bold"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/txtEnrollStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap on an Eye Image above to start capturing."
        android:textAlignment="center"
        android:textStyle="bold"
        android:textColor="#334155"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnStopCapture"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Stop Capture"
        android:backgroundTint="#E11D48"
        android:enabled="false"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btnReset"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Reset"
            android:backgroundTint="#64748B"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnSaveUser"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Save User"
            android:backgroundTint="#0F172A"
            android:enabled="true"/>
    </LinearLayout>

</LinearLayout>